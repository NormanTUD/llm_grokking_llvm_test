#!/bin/bash
#SBATCH --job-name=paper_tests
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --gres=gpu:1
#SBATCH --cpus-per-task=8
#SBATCH --mem=64G
#SBATCH --time=04:00:00
#SBATCH --output=paper_tests_%j.out
#SBATCH --error=paper_tests_%j.err

set -euo pipefail

# ── Bootstrap uv if not available ──
if ! command -v uv &> /dev/null; then
    echo "Installing uv..."
    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="$HOME/.local/bin:$PATH"
fi

echo "Using uv: $(which uv)"
echo "Node: $(hostname)"
echo "GPU:  $(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null || echo 'none')"
echo "Starting paper claims tests at $(date)"

# ── Run with uv (handles all deps automatically) ──
# Default: gpt2 on GPU, full suite
uv run --quiet test_paper_claims.py --model gpt2 --device cuda -v

# Optionally test with a larger model:
# uv run --quiet test_paper_claims.py --model EleutherAI/pythia-410m --device cuda -v

echo "Finished at $(date)"
